#include <winver.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
 FILEFLAGS      VS_FF_DEBUG
#else
 FILEFLAGS      0x0L
#endif
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_DLL
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName",      "@SVGPREVIEW_COMPANY@"
            VALUE "FileDescription",  "@SVGPREVIEW_DESCRIPTION@"
            VALUE "FileVersion",      "@PROJECT_VERSION@.0"
            VALUE "InternalName",     "SvgPreview.dll"
            VALUE "LegalCopyright",   "@SVGPREVIEW_COPYRIGHT@"
            VALUE "OriginalFilename", "SvgPreview.dll"
            VALUE "ProductName",      "@SVGPREVIEW_PRODUCT@"
            VALUE "ProductVersion",   "@PROJECT_VERSION@.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        /* U.S. English (0x0409), Unicode (0x04B0 = 1200) */
        VALUE "Translation", 0x409, 1200
    END
END
